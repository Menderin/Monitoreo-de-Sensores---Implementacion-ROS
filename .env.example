# ==============================================================================
# Credenciales MongoDB Atlas — Monitoreo de Microalgas UCN
# ==============================================================================
# Copiar este archivo a database/.env y rellenar los valores.
#
#   cp .env.example database/.env
#   nano database/.env
# ==============================================================================

# URI de conexión a MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/
MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos
MONGO_DB=Datos_ESP

# Colección de lecturas de sensores
MONGO_COLLECTION=sensors_data

# Colección de registro de dispositivos
MONGO_COLLECTION_DISPOSITIVOS=devices_data

# ==============================================================================
# Notificaciones Telegram — smart_alerter.py / smart_reporter.py
# ==============================================================================
# Obtén el token creando un bot con @BotFather en Telegram.
# Obtén tu CHAT_ID hablando con @userinfobot en Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
